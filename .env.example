# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Square ─────────────────────────────────────────────────────────────────────
# Get these from https://developer.squareup.com/apps
NEXT_PUBLIC_SQUARE_APP_ID=sandbox-sq0idb-xxxxxxxx     # your Square App ID
SQUARE_ACCESS_TOKEN=EAAAxxxxxxxx                       # Sandbox or Production token
SQUARE_LOCATION_ID=Lxxxxxxxxxxxxxxxx                   # From Square Dashboard > Locations
SQUARE_ENVIRONMENT=sandbox                             # 'sandbox' or 'production'

# Webhook: after creating webhook in Square Dashboard, copy the signature key here
SQUARE_WEBHOOK_SIGNATURE_KEY=xxxxxxxx
SQUARE_WEBHOOK_URL=https://spdcertprep.com/api/payment/webhook

# Pro subscription plan — create a subscription plan in Square Dashboard
# Catalog > Subscription Plans > Create, then copy the Plan Variation ID
SQUARE_PRO_PLAN_VARIATION_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://spdcertprep.com

# Used to protect /api/payment/setup-db
SETUP_SECRET=your-long-random-secret

# ── AI Chat (Claude) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
